# Database - SQLite for local development (use PostgreSQL URL for production)
DATABASE_URL="file:./dev.db"

# NextAuth (required for sign-in to work)
NEXTAUTH_SECRET="generate-a-secure-secret"
# Must match the URL you open in the browser (e.g. use http://localhost:3002 if the app runs on port 3002)
NEXTAUTH_URL="http://localhost:3000"

# Optional: AI features (OpenAI)
# OPENAI_API_KEY="sk-..."

# Optional: Moderator emails for trust & safety (comma-separated)
# MODERATOR_EMAILS="mod@example.com,admin@example.com"

# Optional: Email notifications (Resend)
# RESEND_API_KEY="re_..."
# EMAIL_FROM="Projektor <notifications@yourdomain.com>"

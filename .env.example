# Database (PostgreSQL required — Prisma schema is postgres)
# Local: Neon dev branch / Docker Postgres / or a dedicated local DB.
# Production: Neon / RDS / etc.
DATABASE_URL="postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require"

# NextAuth launch requirements (required for app startup/sign-in)
# MUST be set in every environment. Use a long, random secret.
NEXTAUTH_SECRET="replace-with-a-long-random-secret"
# MUST exactly match the browser origin used to access the app (scheme + host + port).
# Examples: http://localhost:3000, https://app.yourdomain.com
NEXTAUTH_URL="http://localhost:3000"
# Optional: Google OAuth sign in
# GOOGLE_CLIENT_ID="..."
# GOOGLE_CLIENT_SECRET="..."

# Optional: AI features (OpenAI)
# OPENAI_API_KEY="sk-..."

# Optional: Moderator emails for trust & safety (comma-separated)
# MODERATOR_EMAILS="mod@example.com,admin@example.com"

# Optional: Email notifications (Resend)
# RESEND_API_KEY="re_..."
# EMAIL_FROM="Projektor <notifications@yourdomain.com>"

# Optional: Redis (recommended for production shared rate limits)
# REDIS_URL="redis://localhost:6379"

# Optional: Sentry error monitoring (set all three on Vercel for production)
# Create a Next.js project at https://sentry.io — copy DSN and slugs from project settings.
# NEXT_PUBLIC_SENTRY_DSN="https://xxxx@xxxx.ingest.de.sentry.io/xxxx"
# SENTRY_ORG="your-org-slug"
# SENTRY_PROJECT="your-project-slug"
# Optional: upload source maps in CI / Vercel builds (keep secret)
# SENTRY_AUTH_TOKEN="sntrys_..."
